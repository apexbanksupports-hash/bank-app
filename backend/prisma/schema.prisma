generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  firstName      String
  lastName       String
  phone          String?
  dateOfBirth    String?
  address        String?
  twoFactorSecret String?
  twoFactorEnabled Boolean   @default(false)
  kycStatus      String        @default("pending")
  role           String        @default("user")
  emailVerified  Boolean       @default(false)
  emailVerificationToken String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  kycDocuments       KycDocument[]
  accounts           Account[]
  sentTransfers      Transfer[]         @relation("SentTransfers")
  receivedTransfers  Transfer[]         @relation("ReceivedTransfers")
  notifications      Notification[]
  scheduledTransfers ScheduledTransfer[] @relation("ScheduledSender")
  receivedScheduled  ScheduledTransfer[] @relation("ScheduledRecipient")
  passwordResets     PasswordResetToken[]
  categories         TransactionCategory[]
  safeboxes           SafeBox[]
  luckySpins          LuckySpin[]
  dailyRewards        DailyReward[]
}

model KycDocument {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  filePath  String
  status    String   @default("pending")
  reviewedBy String?
  reviewNote String?
  createdAt DateTime @default(now())
}

model Account {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  accountNumber String   @unique
  accountType   String   @default("checking")
  currency      String   @default("USD")
  balance       Float    @default(0.0)
  isActive      Boolean  @default(true)
  closedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Transfer {
  id                 String   @id @default(uuid())
  senderId           String
  sender             User     @relation("SentTransfers", fields: [senderId], references: [id])
  recipientId        String
  recipient          User     @relation("ReceivedTransfers", fields: [recipientId], references: [id])
  amount             Float
  currency           String   @default("USD")
  description        String?
  referenceNumber    String   @unique
  status             String   @default("completed")
  categoryId         String?
  category           TransactionCategory? @relation(fields: [categoryId], references: [id])
  reversedFromId     String?
  reversedFrom       Transfer? @relation("TransferReversals", fields: [reversedFromId], references: [id])
  reversals          Transfer[] @relation("TransferReversals")
  senderAccountId    String?
  recipientAccountId String?
  createdAt          DateTime @default(now())
  completedAt        DateTime @default(now())
}

model TransactionCategory {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  name      String
  icon      String     @default("📦")
  color     String     @default("#6B7280")
  transfers Transfer[]
  createdAt DateTime   @default(now())
}

model ScheduledTransfer {
  id              String   @id @default(uuid())
  senderId        String
  sender          User     @relation("ScheduledSender", fields: [senderId], references: [id])
  recipientId     String
  recipient       User     @relation("ScheduledRecipient", fields: [recipientId], references: [id])
  amount          Float
  currency        String   @default("USD")
  description     String?
  frequency       String   @default("once")
  nextRunDate     DateTime
  lastRunDate     DateTime?
  endDate         DateTime?
  runCount        Int      @default(0)
  maxRuns         Int?
  isActive        Boolean  @default(true)
  senderAccountId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SafeBox {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String   @default("My SafeBox")
  balance     Float    @default(0.0)
  targetAmount Float?
  interestRate Float   @default(0.02)
  lockedUntil  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LuckySpin {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  prize     Float
  multiplier String   @default("1x")
  usedAt    DateTime @default(now())
}

model DailyReward {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @default(now())
  reward    Float    @default(0.0)
  streak    Int      @default(1)
}
